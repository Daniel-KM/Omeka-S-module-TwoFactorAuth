{
    "name": "daniel-km/omeka-s-module-two-factor-auth",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Add a security mechanism with a second step to log in with a numeric code sent to user email.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "authentication",
        "security",
        "two factor authentication",
        "2FA"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-TwoFactorAuth",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-TwoFactorAuth/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2432)": {
        "omeka/omeka-s": "^4.0",
        "daniel-km/omeka-s-module-common": "*"
    },
    "autoload": {
        "psr-4": {
            "TwoFactorAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TwoFactorAuthTest\\": "tests/TwoFactorAuthTest/"
        }
    },
    "extra": {
        "installer-name": "TwoFactorAuth",
        "configurable": true
    }
}
